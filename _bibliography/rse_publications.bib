@article{Anzt2021,
  author    = {Hartwig Anzt and Felix Bach and Stephan Druskat and Frank Löffler and Axel Loewe and Bernhard Y. Renard and Gunnar Seemann and Alexander Struck and Elke Achhammer and Piush Aggarwal and Franziska Appel and Michael Bader and Lutz Brusch and Christian Busse and Gerasimos Chourdakis and Piotr W. Dabrowski and Peter Ebert and Bernd Flemisch and Sven Friedl and Bernd Fritzsch and Maximilian D. Funk and Volker Gast and Florian Goth and Jean-Noël Grad and Sibylle Hermann and Florian Hohmann and Stephan Janosch and Dominik Kutra and Jan Linxweiler and Thilo Muth and Wolfgang Peters-Kottig and Fabian Rack and Fabian H. C. Raters and Stephan Rave and Guido Reina and Malte Reißig and Timo Ropinski and Joerg Schaarschmidt and Heidi Seibold and Jan P. Thiele and Benjamin Uekermann and Stefan Unger and Rudolf Weeber},
  title     = {An environment for sustainable research software in {Germany} and beyond: current state, open challenges, and call for action},
  journal   = {F1000Research},
  year      = {2021},
  volume    = {9},
  pages     = {295},
  doi       = {10.12688/f1000research.23224.2},
  url       = {https://doi.org/10.12688/f1000research.23224.2},
  abstract  = {Research software has become a central asset in academic research. It optimizes existing and enables new research processes, through offering immense flexibility for the implementation of research ideas. However, unless carefully maintained, research software rapidly loses its ability to reproduce and build upon previously obtained research results. This requires a change in the academic culture and requires measures ensuring that research software is sustainably developed and openly shared. Here we provide an overview of the current status of research software development in Germany as a specific example of a country with a large and well-funded research landscape. We report on the challenges thwarting current efforts to ensure sustainable research software development and distribution. Besides technical challenges, we identify the lack of an environment supportive of sustainable research software development as the key problem. Drawing on the expertise of our community and existing successful examples, we suggest strategies and measures to address the challenges identified. With this, we aim to contribute to an ongoing international discussion on how to ensure that research software development follows best practices and that software itself becomes a fully recognized and re-usable scientific artifact.}
}

@article{Gruber2023,
  author    = {Tobias Gruber and Maren Issel and Gian-Luca Klein and Heike Neuroth and Karsten Peters-von Gehlen and Tobias Schlauch and Jan Philipp Thiele},
  title     = {Recommendations for research software as a first-class citizen in research data management},
  journal   = {Bausteine Forschungsdatenmanagement},
  year      = {2023},
  volume    = {1},
  pages     = {11--23},
  doi       = {10.17192/bfdm.2023.1.8407},
  url       = {https://doi.org/10.17192/bfdm.2023.1.8407},
  abstract  = {Research software is an important part of modern research and thus also relevant for research data management. Nevertheless, it is often not treated with the same care as research data. In this article, we provide recommendations for how research software should be handled as a first-class citizen in research data management.}
}

@inproceedings{Druskat2021,
  author    = {Stephan Druskat and Jurriaan H. Spaaks and Neil Chue Hong and Robert Haines and James Baker and Spencer Bliven and Egon Willighagen and David Pérez-Suárez and Alexander Konovalov},
  title     = {{Citation File Format}},
  booktitle = {Journal of Open Source Software},
  year      = {2021},
  volume    = {6},
  number    = {54},
  pages     = {3169},
  doi       = {10.21105/joss.03169},
  url       = {https://doi.org/10.21105/joss.03169},
  abstract  = {The Citation File Format (CFF) is a human- and machine-readable file format in YAML 1.2 which provides citation metadata for software. It is supported by GitHub, Zenodo, and Zotero, and can be used to make software citable.}
}

@article{Barker2022,
  author    = {Michelle Barker and Neil P. Chue Hong and Daniel S. Katz and Anna-Lena Lamprecht and Carlos Martinez-Ortiz and Fotis Psomopoulos and Jennifer Harrow and Leyla Jael Castro and Morane Gruenpeter and Paula Andrea Martinez and Tom Honeyman},
  title     = {Introducing the {FAIR} Principles for Research Software},
  journal   = {Scientific Data},
  year      = {2022},
  volume    = {9},
  pages     = {622},
  doi       = {10.1038/s41597-022-01710-x},
  url       = {https://doi.org/10.1038/s41597-022-01710-x},
  abstract  = {Research software is a fundamental and vital part of research, yet significant challenges to discoverability, productivity, quality, reproducibility, and sustainability exist. Improvements are needed to ensure research software is developed following best practices that encourage open and FAIR data principles. Here we introduce and discuss the FAIR Principles for Research Software (FAIR4RS Principles). These principles are a specialization of the FAIR Principles for scientific data management and stewardship. The FAIR4RS Principles are: Findable, Accessible, Interoperable, Reusable.}
}

@article{Goedicke2019,
  author    = {Michael Goedicke and Carola Lilienthal and Tobias Rötschke and Axel Uhl},
  title     = {Technical Debt and Its Relation to {Software Quality} and {Software Maintainability}},
  journal   = {IEEE Software},
  year      = {2019},
  volume    = {36},
  number    = {6},
  pages     = {84--88},
  doi       = {10.1109/MS.2019.2924644},
  url       = {https://doi.org/10.1109/MS.2019.2924644},
  abstract  = {Technical debt represents the implied cost of additional rework caused by choosing an easy solution now instead of a better approach that would take longer. This article discusses technical debt in the context of software quality and maintainability.}
}

@article{Chue_Hong2022,
  author    = {Neil P. Chue Hong and Alice Allen and Carlos Martinez and Joanna Leng and Stephan Druskat and Daniel S. Katz and Aleksandra Nenadic and David Perez-Suarez and Shoaib Sufi},
  title     = {{FAIR4RS}: making research software more {FAIR}},
  journal   = {Data Intelligence},
  year      = {2022},
  volume    = {4},
  number    = {2},
  pages     = {401--422},
  doi       = {10.1162/dint_a_00140},
  url       = {https://doi.org/10.1162/dint_a_00140},
  abstract  = {The FAIR principles for research data were published in 2016 and have had a major impact on how data is shared and reused. The FAIR for Research Software (FAIR4RS) working group has been developing a set of FAIR principles adapted specifically for research software, taking into account the unique characteristics of software compared to data.}
}

@inproceedings{Katz2020,
  author    = {Daniel S. Katz and Stephan Druskat and Robert Haines and Caroline Jay and Alexander Struck},
  title     = {The State of Sustainable Research Software: Learning from the {Workshop} on Sustainable Software for Science: Practice and Experiences ({WSSSPE})},
  booktitle = {Journal of Open Research Software},
  year      = {2020},
  volume    = {7},
  number    = {1},
  doi       = {10.5334/jors.242},
  url       = {https://doi.org/10.5334/jors.242},
  abstract  = {The Workshop on Sustainable Software for Science: Practice and Experiences (WSSSPE) has been a recurring workshop series that focuses on the development, deployment, and sustainment of reusable, open source research software. This paper reports on the state of sustainable research software based on a survey conducted at WSSSPE events.}
}

