@article{bechhofer_research_2010,
  abstract      = {Abstract What will researchers be publishing in the future? Whilst there is little question that the Web will be the publication platform, as scholars move away from paper towards digital content, there is a need for mechanisms that support the production of self-contained units of knowledge and facilitate the publication, sharing and reuse of such entities. In this paper we discuss the notion of research objects , semantically rich aggregations of resources, that can possess some scientific intent or support some research objective. We present a number of principles that we expect such objects and their associated services to follow.},
  author        = {Bechhofer, Sean and De Roure, David and Gamble, Matthew and Goble, Carole and Buchan, Iain},
  doi           = {10.1038/npre.2010.4626.1},
  issn          = {1756-0357},
